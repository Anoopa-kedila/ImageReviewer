<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:opvm="clr-namespace:ImageReviewerApp.ViewModels.OperationParameters">

    <!-- Window/Level Parameters Template -->
    <DataTemplate DataType="{x:Type opvm:WindowLevelParametersViewModel}">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Window:" VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="Bold"/>
            <Slider Width="150" Minimum="1000" Maximum="65536" Value="{Binding Window}" 
                    VerticalAlignment="Center" TickFrequency="1000" IsSnapToTickEnabled="False"/>
            <TextBlock Text="{Binding Window, StringFormat=N0}" Width="60" VerticalAlignment="Center" Margin="5,0"/>

            <TextBlock Text="Level:" VerticalAlignment="Center" Margin="20,0,5,0" FontWeight="Bold"/>
            <Slider Width="150" Minimum="0" Maximum="65535" Value="{Binding Level}" 
                    VerticalAlignment="Center" TickFrequency="1000" IsSnapToTickEnabled="False"/>
            <TextBlock Text="{Binding Level, StringFormat=N0}" Width="60" VerticalAlignment="Center" Margin="5,0"/>
        </StackPanel>
    </DataTemplate>

    <!-- Gamma Parameters Template -->
    <DataTemplate DataType="{x:Type opvm:GammaParametersViewModel}">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Gamma:" VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="Bold"/>
            <Slider Width="200" Minimum="0.1" Maximum="5.0" Value="{Binding Gamma}" 
                    VerticalAlignment="Center" TickFrequency="0.1" IsSnapToTickEnabled="False"/>
            <TextBlock Text="{Binding Gamma, StringFormat=F2}" Width="50" VerticalAlignment="Center" Margin="5,0"/>
        </StackPanel>
    </DataTemplate>

    <!-- Median Filter Parameters Template -->
    <DataTemplate DataType="{x:Type opvm:MedianFilterParametersViewModel}">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Kernel Size:" VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="Bold"/>
            <ComboBox Width="100" SelectedValue="{Binding KernelSize}" SelectedValuePath="Tag" VerticalAlignment="Center">
                <ComboBoxItem Content="3×3" Tag="3" IsSelected="True"/>
                <ComboBoxItem Content="5×5" Tag="5"/>
                <ComboBoxItem Content="7×7" Tag="7"/>
            </ComboBox>
        </StackPanel>
    </DataTemplate>

    <!-- Thresholding Parameters Template -->
    <DataTemplate DataType="{x:Type opvm:ThresholdParametersViewModel}">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Threshold:" VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="Bold"/>
            <Slider Width="250" Minimum="0" Maximum="65535" Value="{Binding Threshold}" 
                    VerticalAlignment="Center" TickFrequency="1000" IsSnapToTickEnabled="False"/>
            <TextBlock Text="{Binding Threshold, StringFormat=N0}" Width="60" VerticalAlignment="Center" Margin="5,0"/>
        </StackPanel>
    </DataTemplate>

    <!-- Gaussian Filter Parameters Template -->
    <DataTemplate DataType="{x:Type opvm:GaussianFilterParametersViewModel}">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Kernel Size:" VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="Bold"/>
            <ComboBox Width="100" SelectedValue="{Binding KernelSize}" SelectedValuePath="Tag" VerticalAlignment="Center">
                <ComboBoxItem Content="3×3" Tag="3"/>
                <ComboBoxItem Content="5×5" Tag="5" IsSelected="True"/>
                <ComboBoxItem Content="7×7" Tag="7"/>
            </ComboBox>

            <TextBlock Text="Sigma:" VerticalAlignment="Center" Margin="20,0,5,0" FontWeight="Bold"/>
            <Slider Width="150" Minimum="0.1" Maximum="5.0" Value="{Binding Sigma}" 
                    VerticalAlignment="Center" TickFrequency="0.1" IsSnapToTickEnabled="False"/>
            <TextBlock Text="{Binding Sigma, StringFormat=F2}" Width="50" VerticalAlignment="Center" Margin="5,0"/>
        </StackPanel>
    </DataTemplate>

    <!-- Bad Pixel Suppression Parameters Template -->
    <DataTemplate DataType="{x:Type opvm:BadPixelSuppressionParametersViewModel}">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="Detection Threshold (σ):" VerticalAlignment="Center" Margin="10,0,5,0" FontWeight="Bold"/>
            <Slider Width="150" Minimum="1.0" Maximum="5.0" Value="{Binding Threshold}" 
                    VerticalAlignment="Center" TickFrequency="0.5" IsSnapToTickEnabled="False"/>
            <TextBlock Text="{Binding Threshold, StringFormat=F1}" Width="40" VerticalAlignment="Center" Margin="5,0"/>

            <TextBlock Text="Neighborhood:" VerticalAlignment="Center" Margin="20,0,5,0" FontWeight="Bold"/>
            <ComboBox Width="100" SelectedValue="{Binding KernelSize}" SelectedValuePath="Tag" VerticalAlignment="Center">
                <ComboBoxItem Content="3×3" Tag="3" IsSelected="True"/>
                <ComboBoxItem Content="5×5" Tag="5"/>
                <ComboBoxItem Content="7×7" Tag="7"/>
            </ComboBox>
        </StackPanel>
    </DataTemplate>

    <!-- No Parameters Template -->
    <DataTemplate DataType="{x:Type opvm:NoParametersViewModel}">
        <!-- Empty template - no UI needed for operations without parameters -->
    </DataTemplate>

</ResourceDictionary>
