        <Window x:Class="ImageReviewerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageReviewerApp"
        xmlns:viewmodels="clr-namespace:ImageReviewerApp.ViewModels"
        mc:Ignorable="d"
        Title="Image Reviewer" 
        Height="900" Width="1600"
        MinHeight="700" MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Background="White"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#0078D4" Height="32" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Application Icon and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8B9;" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="White" Margin="0,0,8,0"/>
                    <TextBlock Text="Image Reviewer" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window Control Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xE921;" Style="{StaticResource WindowButtonStyle}" Click="MinimizeButton_Click" ToolTip="Minimize"/>
                    <Button Content="&#xE922;" Style="{StaticResource WindowButtonStyle}" Click="MaximizeButton_Click" ToolTip="Maximize"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click" ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#F3F3F3" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Main Toolbar -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Button Content="Load Image" 
                            Command="{Binding LoadImageCommand}"
                            Style="{StaticResource ModernButtonStyle}"/>

                    <Separator Width="10" Background="Transparent"/>

                    <TextBlock Text="Operation:" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>
                    <ComboBox ItemsSource="{Binding AvailableOperations}"
                              SelectedItem="{Binding SelectedOperation}"
                              Width="200"
                              Margin="5"
                              FontSize="14"/>

                    <Button Content="Apply" 
                            Command="{Binding ApplyOperationCommand}"
                            Style="{StaticResource ModernButtonStyle}"/>

                    <Button Content="Cancel" 
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#FFA500"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}"
                            ToolTip="Cancel current operation"/>

                    <Button Content="Reset" 
                            Command="{Binding ResetCommand}"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#FF6B6B"/>

                    <Button Content="Save Image" 
                            Command="{Binding SaveImageCommand}"
                            Style="{StaticResource ModernButtonStyle}"
                            Background="#51CF66"/>
                </StackPanel>

                <ContentPresenter Grid.Row="1" 
                                  Content="{Binding ParameterManager.CurrentParameters}"
                                  Margin="0,10,0,0"
                                  VerticalAlignment="Center"/>

            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Original Image Panel -->
            <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0078D4" Padding="10">
                        <TextBlock Text="Original Image" Foreground="White" FontWeight="Bold" FontSize="16"/>
                    </Border>

                    <Image Grid.Row="1" 
                           Source="{Binding OriginalDisplayImage}" 
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- Placeholder when no image -->
                    <TextBlock Grid.Row="1" 
                               Text="No image loaded" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               FontSize="16" 
                               Foreground="#999999"
                               Visibility="{Binding OriginalDisplayImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" Background="#E0E0E0"/>

            <!-- Processed Image Panel -->
            <Border Grid.Column="2" BorderBrush="#E0E0E0" BorderThickness="1" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#51CF66" Padding="10">
                        <TextBlock Text="Processed Image" Foreground="White" FontWeight="Bold" FontSize="16"/>
                    </Border>

                    <Image Grid.Row="1" 
                           Source="{Binding ProcessedDisplayImage}" 
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- Placeholder when no processed image -->
                    <TextBlock Grid.Row="1" 
                               Text="No processed image" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               FontSize="16" 
                               Foreground="#999999"
                               Visibility="{Binding ProcessedDisplayImage, Converter={StaticResource NullToVisibilityConverter}}"/>
                </Grid>
            </Border>

            <!-- Metadata Panel -->
            <Border Grid.Column="3" BorderBrush="#E0E0E0" BorderThickness="1" Background="White" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#495057" Padding="10">
                        <TextBlock Text="Image Metadata" Foreground="White" FontWeight="Bold" FontSize="16"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Dimensions" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#0078D4"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Width:" Style="{StaticResource MetadataLabelStyle}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ImageMetadata.Width, StringFormat={}{0} px}" Style="{StaticResource MetadataValueStyle}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Height:" Style="{StaticResource MetadataLabelStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ImageMetadata.Height, StringFormat={}{0} px}" Style="{StaticResource MetadataValueStyle}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Bit Depth:" Style="{StaticResource MetadataLabelStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ImageMetadata.BitDepth, StringFormat={}{0} bits}" Style="{StaticResource MetadataValueStyle}"/>
                            </Grid>

                            <Separator Margin="0,15" Background="#E0E0E0"/>

                            <TextBlock Text="Intensity Statistics" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#0078D4"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Min:" Style="{StaticResource MetadataLabelStyle}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ImageMetadata.MinIntensity}" Style="{StaticResource MetadataValueStyle}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Max:" Style="{StaticResource MetadataLabelStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ImageMetadata.MaxIntensity}" Style="{StaticResource MetadataValueStyle}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Mean:" Style="{StaticResource MetadataLabelStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ImageMetadata.MeanIntensity, StringFormat={}{0:F2}}" Style="{StaticResource MetadataValueStyle}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#F3F3F3" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ProgressBar Value="{Binding ProgressPercentage}" 
                                 Width="200" 
                                 Height="20" 
                                 Margin="10,0"/>
                    <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0}%}" 
                               VerticalAlignment="Center"
                               Margin="10,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
